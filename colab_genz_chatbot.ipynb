fp16_flag = bool(torch.cuda.is_available())

training_args = TrainingArguments(
    output_dir="./genz-chatbot",
    overwrite_output_dir=True,
    num_train_epochs=3,
    per_device_train_batch_size=2,
    save_steps=500,
    save_total_limit=2,
    logging_steps=50,
    warmup_steps=20,
    learning_rate=5e-4,
    fp16=fp16_flag,
)

data_collator = DataCollatorForLanguageModeling(
    tokenizer=tokenizer,
    mlm=False,
)

trainer = Trainer(
    model=model,
    args=training_args,
    data_collator=data_collator,
    train_dataset=tokenized_dataset,
)# Cell 8: Tokenize the data

def tokenize_function(examples):
    return tokenizer(
        examples["text"],
        truncation=True,
        padding="max_length",
        max_length=256,
    )

tokenized_dataset = dataset.map(tokenize_function, batched=True, remove_columns=["text"])# Cell 7: Setup LoRA for efficient training
lora_config = LoraConfig(
    task_type=TaskType.CAUSAL_LM,
    r=16,
    lora_alpha=32,
    lora_dropout=0.1,
    target_modules=["c_attn", "c_proj"],
)

model = get_peft_model(model, lora_config)
model.print_trainable_parameters()# Cell 6: Load model and tokenizer
use_tiny = os.environ.get("USE_TINY", "0") == "1"
model_name = os.environ.get("MODEL_NAME", "microsoft/DialoGPT-medium" if not use_tiny else "sshleifer/tiny-gpt2")

# Token is optional for public models
token_arg = {"token": HF_TOKEN} if 'HF_TOKEN' in globals() and HF_TOKEN else {}

print(f"Loading model: {model_name}")

tokenizer = AutoTokenizer.from_pretrained(model_name, **token_arg)
# Ensure pad token exists
if tokenizer.pad_token_id is None:
    tokenizer.pad_token = tokenizer.eos_token

dtype = torch.float16 if torch.cuda.is_available() else None

model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=dtype,
    device_map="auto" if torch.cuda.is_available() else None,
    **token_arg,
)

# For GPT2-like models, align pad token id
if model.config.pad_token_id is None:
    model.config.pad_token_id = tokenizer.pad_token_id

print("Model and tokenizer loaded.")# Cell 5: Format data for training

