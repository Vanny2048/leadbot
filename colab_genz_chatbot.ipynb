# Cell 12: Save artifacts
SAVE_DIR = os.environ.get("SAVE_DIR", "./genz-chatbot-final")

# Only save if we trained or if you want to snapshot current adapter state
DO_SAVE = os.environ.get("DO_SAVE", "1") == "1"

if DO_SAVE:
    model.save_pretrained(SAVE_DIR)
    tokenizer.save_pretrained(SAVE_DIR)
    print(f"Model and tokenizer saved to {SAVE_DIR}")
else:
    print("Skipping save (set DO_SAVE=1 to enable)")# Cell 11: Test your model (generation)

def generate_response(prompt: str, max_new_tokens: int = 50) -> str:
    model.eval()
    formatted_prompt = f"### Human: {prompt}\n### Assistant:"
    inputs = tokenizer(formatted_prompt, return_tensors="pt")
    inputs = {k: v.to(model.device) for k, v in inputs.items()}

    with torch.no_grad():
        output_ids = model.generate(
            **inputs,
            max_new_tokens=max_new_tokens,
            num_return_sequences=1,
            temperature=0.8,
            top_p=0.9,
            do_sample=True,
            pad_token_id=tokenizer.pad_token_id,
            eos_token_id=tokenizer.eos_token_id,
            repetition_penalty=1.1,
        )[0]

    text = tokenizer.decode(output_ids, skip_special_tokens=True)
    if "### Assistant:" in text:
        return text.split("### Assistant:")[-1].strip()
    return text.strip()

# Quick smoke test
for p in ["hey how's it going", "I need help with homework", "what should I do tonight"]:
    print("You:", p)
    print("Bot:", generate_response(p), "\n")# Cell 10: Start training (optional)
